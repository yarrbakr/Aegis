# Backend env — copy to `backend/.env` (never commit real values).
# These stay server-side only and are NEVER sent to the browser.

# LLM providers (both free, OpenAI-compatible)
GROQ_API_KEY=your-groq-key
MISTRAL_API_KEY=your-mistral-key

# Supabase — service role key is server-side ONLY (bypasses RLS; never expose it)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS: deployed frontend origin(s), comma-separated. Use "*" for local dev.
FRONTEND_ORIGIN=*
