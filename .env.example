# Frontend env — copy to `.env.local` (never commit real values).
# Next.js only exposes vars prefixed with NEXT_PUBLIC_ to the browser.

# Supabase project (Supabase dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# FastAPI backend base URL (Render URL in prod, localhost in dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
