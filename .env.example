# App env — copy to `.env.local` (never commit real values).
# Next.js exposes ONLY vars prefixed with NEXT_PUBLIC_ to the browser.
# Everything else stays server-side, used inside the Next.js Route Handler
# (all-Vercel — the AI generation + guardrail run there, not a separate service).

# Supabase project (Supabase dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# LLM providers — SERVER-SIDE ONLY (never NEXT_PUBLIC_, never committed).
# Groq is primary; Mistral is the fallback (used if Groq is down or hits its
# free daily token cap). Both are free + OpenAI-compatible.
GROQ_API_KEY=your-groq-key
MISTRAL_API_KEY=your-mistral-key

# Optional — only to apply supabase/schema.sql + migrations from the CLI.
# Supabase -> Project Settings -> Database -> Connection string -> Session pooler.
# NOT read by the app at runtime.
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST.pooler.supabase.com:5432/postgres
